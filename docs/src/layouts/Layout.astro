---
import "../style/style.scss";
import Navbar from "../components/Navbar.astro";
import Sidebar from "../components/Sidebar.astro";
import WipWarning from "../components/WipWarning.astro";

interface Props {
	title?: string;
}

const { title = "Worker Image CDN" } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<title>{title}</title>
	</head>
	<body>
		<WipWarning />
		<Navbar />
		<Sidebar />
		<main>
			<slot />
			<footer>
				Built by <a href="https://github.com/FrancescoCiannavei" target="_blank" rel="noopener">Francesco Ciannavei</a>
			</footer>
		</main>
	</body>
</html>

<style lang="scss">
	@use "../style/vars" as *;

	main {
		margin-left: $sidebarWidth;
		margin-top: $navHeight;
		padding: 40px 48px;
		max-width: 800px;
	}

	footer {
		margin-top: 60px;
		padding-top: 20px;
		border-top: 1px solid $borderCol;
		font-size: 0.8rem;
		color: $textSecondary;

		a {
			color: $textSecondary;
			text-decoration: underline;

			&:hover {
				color: #fff;
			}
		}
	}
</style>
